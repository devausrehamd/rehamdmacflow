# Brewfile for the QMS Agent project
# Install with: brew bundle
#
# Node.js is managed by nvm, not brew. See .nvmrc.

# Core tooling
brew "git"
brew "jq"

# Local AI stack
brew "ollama"
brew "redis"
brew "postgresql@17"

# Container runtime (open source)
brew "colima"
brew "docker"

# Optional but recommended
brew "watch"
brew "httpie"
