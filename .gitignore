# Dependencies
node_modules/

# Environment / local secrets
.env
.env.local

# Ingestion cache (fetched + converted source docs)
.ingest-cache/

# Local-only ingestion config (use config/ingestion.local.example.json as a template)
config/ingestion.local.json

# Build output
dist/

# macOS
.DS_Store

# Logs
*.log

# Per-INSTANCE identity. The GUID names a running agent and its Discovery
# lease hangs off it, so two clones sharing one GUID would clobber each
# other in the registry. Generated on first start; never part of the codebase.
identity/agent-guid*.txt
