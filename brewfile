# Brewfile for the QMS Agent project
# Install everything in this file with:
#   brew bundle
#
# This file is idempotent. Re-running it on a machine that already has
# the packages does nothing.
#
# Note: Node.js is NOT managed via brew. Use nvm (Node Version Manager)
# and the .nvmrc file at the project root. This avoids version conflicts
# between projects and prevents Homebrew-related linking issues.
# Install nvm: https://github.com/nvm-sh/nvm

# Core tooling
brew "git"
brew "jq"

# Local AI stack
brew "ollama"
brew "redis"

# Container runtime (open source)
# Colima provides a Docker-compatible daemon in a lightweight Linux VM.
# The docker CLI is separate; both are required.
brew "colima"
brew "docker"

# Optional but recommended
brew "watch"
brew "httpie"
