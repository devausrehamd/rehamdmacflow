{
  "name": "qms-agent",
  "version": "0.1.0",
  "description": "Local QMS document drafting agent built on LangGraph.js, Ollama, Qdrant, Redis, and Postgres",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "agent": "tsx src/index.ts",
    "api": "tsx src/api/server.ts",
    "ingest": "tsx src/ingest.ts",
    "ingest:repo": "tsx src/ingestion/cli.ts",
    "test-retrieval": "tsx src/test-retrieval.ts",
    "ask": "tsx src/ask.ts",
    "reset": "tsx scripts/reset-collection.ts",
    "clear:all": "tsx scripts/clear-all.ts",
    "seed": "tsx scripts/seed-project.ts",
    "create-admin": "tsx scripts/create-admin.ts",
    "smoke:dataplane": "tsx scripts/smoke-test-dataplane.ts",
    "smoke:auth": "tsx scripts/smoke-test-auth.ts",
    "smoke:agent": "tsx scripts/smoke-test-agent.ts",
    "smoke:tables": "tsx scripts/smoke-test-tables.ts",
    "smoke:hybrid": "tsx scripts/smoke-test-hybrid.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src scripts --ext .ts",
    "format": "prettier --write \"src/**/*.ts\" \"scripts/**/*.ts\""
  },
  "dependencies": {
    "@langchain/core": "^1.1.48",
    "@langchain/langgraph": "^1.4.0",
    "@langchain/openai": "^1.5.0",
    "@qdrant/js-client-rest": "^1.12.0",
    "bcrypt": "^5.1.1",
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.36.0",
    "express": "^5.0.1",
    "ioredis": "^5.4.0",
    "jsonwebtoken": "^9.0.2",
    "langfuse-langchain": "^3.30.0",
    "mammoth": "^1.8.0",
    "minimatch": "^10.0.0",
    "pdf-parse": "^1.1.1",
    "pg": "^8.13.0",
    "xlsx": "^0.18.5",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.0",
    "@types/pdf-parse": "^1.1.4",
    "@types/pg": "^8.11.10",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "drizzle-kit": "^0.28.0",
    "eslint": "^9.18.0",
    "prettier": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}