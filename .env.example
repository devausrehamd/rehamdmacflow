# Copy this file to .env and adjust values for your machine.

# Ollama (local LLM serving via the OpenAI-compatible API)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5:7b-instruct-q4_K_M
OLLAMA_EMBED_MODEL=mxbai-embed-large

# Qdrant (vector store)
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=qms_documents

# Redis (memory store)
REDIS_HOST=localhost
REDIS_PORT=6379

# QMS source folder (used by the legacy local-folder ingester)
# The git-repo ingestion path uses config/ingestion.json instead.
# Set this to a real folder even if you only use the git ingester,
# because src/config.ts requires it.
QMS_FOLDER=/absolute/path/to/your/QMS

# Agent runtime
LOG_LEVEL=info
